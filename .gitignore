# .NET build output
bin/
obj/
*.user

# Local dev config, generated by infra/scripts/dev-local-setup.* from the deployed env.
# Machine-specific (endpoints) — never commit. The appsettings.Development.json files are
# NOT here on purpose: they are tracked and hold logging levels, so the setup script must
# not touch them; it writes .dev-local/backend.env instead and dev-local.* exports it.
src/Smx.Functions/local.settings.json
.dev-local/

# Compiled ARM output from `az bicep build`
infra/**/main.json
infra/**/modules/*.json

# Local regulatory-corpus data (seed input for the Regulatory Sync; loaded via SeedImporter,
# not stored in git — large official PDFs + scraped text).
Regulations 2/
Regulations/

# Claude code's internal files
.claude/
